<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="hb_bot">

    <!-- ================= GLOBAL PARAMETERS ================= -->
    <xacro:property name="wheel_mass" value="0.05"/>
    <xacro:property name="wheel_radius" value="0.03"/>
    <xacro:property name="wheel_thickness" value="0.01"/>

    <!-- ================= INERTIA MACROS ================= -->

    <xacro:macro name="cylinder_inertia" params="m r h">
        <inertia
            ixx="${m*(3*r*r + h*h)/12}" ixy="0" ixz="0"
            iyy="${m*(3*r*r + h*h)/12}" iyz="0"
            izz="${m*r*r/2}" />
    </xacro:macro>

    <xacro:macro name="box_inertia" params="m x y z">
        <inertia
            ixx="${m*(y*y + z*z)/12}" ixy="0" ixz="0"
            iyy="${m*(x*x + z*z)/12}" iyz="0"
            izz="${m*(x*x + y*y)/12}" />
    </xacro:macro>

    <!-- ================= WHEEL MACRO ================= -->

    <xacro:macro name="rim_macro" params="name xyz rpy mass radius thickness">

        <link name="rim_${name}_link">

            <inertial>
                <origin xyz="0 0 0"/>
                <mass value="${mass}"/>
                <xacro:cylinder_inertia m="${mass}" r="${radius}" h="${thickness}"/>
            </inertial>

            <visual>
                <geometry>
                    <mesh filename="file:///home/deepanshu/My_ROS/src/r_bot/description/meshes/wheels.dae"/>
                </geometry>
            </visual>

            <collision>
                <geometry>
                    <cylinder radius="${radius}" length="${thickness}"/>
                </geometry>
            </collision>

        </link>

        <joint name="rim_${name}_joint" type="continuous">
            <parent link="base_link"/>
            <child link="rim_${name}_link"/>
            <axis xyz="0 0 1"/>
            <limit effort="1.0" velocity="10.0"/>
            <origin xyz="${xyz}" rpy="${rpy}"/>
        </joint>

    </xacro:macro>

    <!-- ================= BASE ================= -->

    <link name="root_link"/>

    <link name="base_link">

        <visual>
            <geometry>
                <mesh filename="file:///home/deepanshu/My_ROS/src/r_bot/description/meshes/hb_crystal.dae"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0.042"/>
            <geometry>
                <cylinder length="0.064" radius="0.08"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0"/>
            <mass value="0.15"/>
            <xacro:cylinder_inertia m="0.15" r="0.074" h="0.03"/>
        </inertial>

    </link>

    <joint name="root_to_base" type="fixed">
        <parent link="root_link"/>
        <child link="base_link"/>
    </joint>

    <!-- BASE_FOOTPRINT LINK -->

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_footprint">
    </link>

    <!-- ================= ARM ================= -->

    <link name="chassis_link"/>
    <link name="arm_root_link"/>

    <link name="arm_link_1">

        <visual>
            <geometry>
                <mesh filename="file:///home/deepanshu/My_ROS/src/r_bot/description/meshes/arm_link.dae"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0.02472"/>
            <geometry>
                <box size="0.008 0.008 0.06"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.001"/>
            <xacro:cylinder_inertia m="0.001" r="0.025" h="0.05"/>
        </inertial>

    </link>

    <link name="arm_link_2">

        <visual>
            <geometry>
                <mesh filename="file:///home/deepanshu/My_ROS/src/r_bot/description/meshes/arm_elbow.dae"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0.025"/>
            <geometry>
                <box size="0.008 0.008 0.05"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.001"/>
            <xacro:cylinder_inertia m="0.001" r="0.025" h="0.05"/>
        </inertial>

    </link>

    <!-- Fixed arm chain -->
    <joint name="base_to_chassis" type="fixed">
        <parent link="base_link"/>
        <child link="chassis_link"/>
        <origin xyz="0 0 0.0795"/>
    </joint>

    <joint name="chassis_to_arm_base" type="fixed">
        <parent link="chassis_link"/>
        <child link="arm_root_link"/>
        <origin xyz="0.075 0 0"/>
    </joint>

    <joint name="arm_base" type="fixed">
        <parent link="arm_root_link"/>
        <child link="arm_link_1"/>
        <origin xyz="0 0 0.013"/>
    </joint>

    <joint name="arm_elbow" type="fixed">
        <parent link="arm_link_1"/>
        <child link="arm_link_2"/>
        <origin xyz="0 0 0.05"/>
    </joint>

    <!-- ================= WHEELS ================= -->

    <xacro:rim_macro
        name="left"
        xyz="0.03600001399230441 0.06235382099401676 -0.001"
        rpy="1.570796326794896 0 -0.523599"
        mass="${wheel_mass}"
        radius="${wheel_radius}"
        thickness="${wheel_thickness}"/>

    <xacro:rim_macro
        name="right"
        xyz="0.03600001399230441 -0.06235382099401676 -0.001"
        rpy="1.570796326794896 0 0.523599"
        mass="${wheel_mass}"
        radius="${wheel_radius}"
        thickness="${wheel_thickness}"/>

    <xacro:rim_macro
        name="back"
        xyz="-0.072 0 0"
        rpy="1.570796326794896 0 1.570796326794896"
        mass="${wheel_mass}"
        radius="${wheel_radius}"
        thickness="${wheel_thickness}"/>

    <!-- ================= CONTROL ================= -->

    <ros2_control name="RobotSystem" type="system">

        <hardware>
            <plugin>gazebo_ros2_control/GazeboSystem</plugin>
        </hardware>

        <joint name="rim_left_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="rim_right_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="rim_back_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

    </ros2_control>

    <!-- ================= GAZEBO ================= -->

    <gazebo>
        <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
            <parameters>/home/deepanshu/My_ROS/src/r_bot/config/Control.yaml</parameters>
        </plugin>
    </gazebo>

</robot>