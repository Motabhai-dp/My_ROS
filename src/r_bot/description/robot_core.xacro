<?xml version="1.0"?>
<robot name="triangular_omni_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  

  <!-- BASE -->
  <link name="base_link"/>

  <!-- CHASSIS -->
  <link name="chassis_link">
    <visual>
      <geometry>
        <mesh filename="file:///home/deepanshu/My_ROS/src/r_bot/description/meshes/hb_crystal.dae" scale="5 5 5"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- WHEELS -->
  <link name="wheel_1">
    <visual>
      <geometry>
        <mesh filename="file:///home/deepanshu/My_ROS/src/r_bot/description/meshes/wheels.dae" scale="5 5 5"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <link name="wheel_2">
    <visual>
      <geometry>
        <mesh filename="file:///home/deepanshu/My_ROS/src/r_bot/description/meshes/wheels.dae" scale="5 5 5"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <link name="wheel_3">
    <visual>
      <geometry>
        <mesh filename="file:///home/deepanshu/My_ROS/src/r_bot/description/meshes/wheels.dae" scale="5 5 5"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- ================= CORRECT ORIENTATION ================= -->

  <!-- Wheel 1 -->
<joint name="wheel_1_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="wheel_1"/>
    <origin xyz="0.2 0 -0.06" rpy="0 1.5708 0"/>
    <axis xyz="0 0 1"/>
</joint>

<!-- Wheel 2 -->
<joint name="wheel_2_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="wheel_2"/>
    <origin xyz="-0.1 0.173 -0.06" rpy="0 1.5708 2.094"/>
    <axis xyz="0 0 1"/>
</joint>

<!-- Wheel 3 -->
<joint name="wheel_3_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="wheel_3"/>
    <origin xyz="-0.1 -0.173 -0.06" rpy="0 1.5708 -2.094"/>
    <axis xyz="0 0 1"/>
</joint>

</robot>